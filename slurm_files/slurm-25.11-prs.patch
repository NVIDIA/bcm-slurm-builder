+/*
+ * globres_update_preemptee_list - get all job ids of jobs in
+ *   preemptee_candidates that are not included in preemptee_job_list.
+ *   Send this list to the globres service with additional list of
+ *   preemptee_job_list ids.
+ *	 The globres service determines if additional jobs from the former list are
+ *   to be preempted and returns their ids. Update preemptee_job_list with the
+ *   additional jobs returned from the globres service.
+ * job_ptr				IN - the job data structure
+ * node_bitmap			IN - current node allocation for the job
+ * preemptee_job_list	IN/OUT - list of job to preempt. Update this list with
+ *   additional jobs to preempt due to the global resource.
+ * preemptee_candidates	IN - all candidates for preemption. Part of those are
+ *   already in preemptee_job_list.
+ */
+extern int globres_update_preemptee_list(job_record_t *job_ptr,
+	bitstr_t *node_bitmap,
+	list_t *preemptee_job_list,
+	list_t *preemptee_candidates)
+{
+	int res = SLURM_SUCCESS;
+	char *url = NULL, *job_nodes_str = NULL;
+	char *preempt_jobids_str = NULL, *preemptee_candidates_jobids_str = NULL;
+	size_t url_len = 0;
+	char job_id_str[12];
+	list_t *preemptee_jobids = NULL, *preemptee_candidates_jobids = NULL;
+	list_t *additional_preemptee_jobids = NULL;
+	list_itr_t *iterator = NULL;
+	response_memory_t response_memory;
+	job_record_t *tmp_job_ptr;
+	bool hero_job = _globres_job_hero(job_ptr);
+	bool gpu_job = _globres_job_request_gpu(job_ptr);
+
+	if (!globres_enabled)
+		return SLURM_SUCCESS;
+
+	preemptee_jobids = list_create(NULL);
+	preemptee_candidates_jobids = list_create(NULL);
+
+	snprintf(job_id_str, sizeof(job_id_str), "%u", job_ptr->job_id);
+
+	globres_get_jobids(preemptee_job_list, preemptee_jobids);
+	preempt_jobids_str = _jobid_list_to_str(preemptee_jobids);
+	if (!preempt_jobids_str) {
+		FREE_NULL_LIST(preemptee_jobids);
+		return SLURM_ERROR;
+	}
+	debug("preempt_jobids_str %s", preempt_jobids_str);
+	FREE_NULL_LIST(preemptee_jobids);
+
+	globres_get_jobids(preemptee_candidates, preemptee_candidates_jobids);
+	preemptee_candidates_jobids_str = _jobid_list_to_str(preemptee_candidates_jobids);
+	if (!preemptee_candidates_jobids_str) {
+		xfree(preempt_jobids_str);
+		FREE_NULL_LIST(preemptee_candidates_jobids);
+		return SLURM_ERROR;
+	}
+	debug("preemptee_candidates_jobids_str %s", preemptee_candidates_jobids_str);
+	FREE_NULL_LIST(preemptee_candidates_jobids);
+
+	job_nodes_str = bitmap2node_name(node_bitmap);
+	url_len = strlen(globres_service_addr) +
+			  strlen("/update_preemptee_list?jobid=") +
+			  strlen(job_id_str) +
+			  strlen("&job_nodes=") +
+			  strlen(job_nodes_str) +
+			  strlen("&is_hero=1") +
+			  strlen("&is_gpu=1") +
+			  strlen("&preempted_jobids=") +
+			  strlen(preempt_jobids_str) +
+			  strlen("&preemptee_candidates_jobids=") +
+			  strlen(preemptee_candidates_jobids_str) +
+			  1; /* Add 1 for null terminator */
+
+	url = xmalloc(url_len);
+	if (!url) {
+		error("Failed to allocate memory for URL");
+		xfree(preempt_jobids_str);
+		xfree(preemptee_candidates_jobids_str);
+		xfree(job_nodes_str);
+		return SLURM_ERROR;
+	}
+
+	snprintf(url,
+			 url_len,
+			 "%s/update_preemptee_list?jobid=%s&job_nodes=%s&is_hero=%d&is_gpu=%d&preempted_jobids=%s&preemptee_candidates_jobids=%s",
+			 globres_service_addr,
+			 job_id_str,
+			 job_nodes_str,
+			 hero_job,
+			 gpu_job,
+			 preempt_jobids_str,
+			 preemptee_candidates_jobids_str);
+	xfree(preempt_jobids_str);
+	xfree(preemptee_candidates_jobids_str);
+	xfree(job_nodes_str);
+
+	res = _send_globres_get(url, &response_memory);
+	if (res != SLURM_SUCCESS) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource server unavailable");
+	} else if (xstrcmp(response_memory.memory, "{\"message\":\"no\"}") == 0) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource insufficient");
+		res = SLURM_ERROR;
+	} else {
+		additional_preemptee_jobids = list_create(NULL);
+		iterator = list_iterator_create(preemptee_candidates);
+		/* Read the response_body, extract the job ids, iterate the
+		   preemptee_candidates and append the ones with matching job ids to
+		   preemptee_job_list */
+
+		if (strcmp(response_memory.memory, "\"\"") != 0) {
+			/* Remove the surrounding quotes */
+			size_t len = strlen(response_memory.memory);
+			if (len > 2 && response_memory.memory[0] == '"' &&
+				response_memory.memory[len - 1] == '"') {
+				/* Copy without quotes */
+				char *temp = strndup(response_memory.memory + 1, len - 2);
+
+				/* Tokenize the string using commas */
+				char *token = strtok(temp, ",");
+				while (token != NULL) {
+					uint32_t jobid = (uint32_t)strtoul(token, NULL, 10);;
+					while ((tmp_job_ptr = list_next(iterator))) {
+						if (tmp_job_ptr->job_id == jobid) {
+							list_append(preemptee_job_list, tmp_job_ptr);
+						}
+					}
+					token = strtok(NULL, ",");
+				}
+
+				free(temp);
+			}
+		}
+
+		list_iterator_destroy(iterator);
+		FREE_NULL_LIST(additional_preemptee_jobids);
+	}
+	xfree(response_memory.memory);
+	xfree(url);
+
+	return res;
+}
