+/*
+ * _globres_job_request_gpu - check if this job requested gpus or not.
+ * job_ptr		IN - the job data structure
+ * RET true if this job requested gpus and false otherwise
+ */
+bool _globres_job_request_gpu(job_record_t *job_ptr)
+{
+	list_itr_t *job_gres_iter;
+	gres_state_t *gres_state_job;
+	bool request_gpu = false;
+	list_t *job_gres_list = job_ptr->gres_list_req_accum;
+
+	if (!globres_enabled)
+		return false;
+
+	if (!job_gres_list || (list_count(job_gres_list) == 0))
+		return false;
+
+	job_gres_iter = list_iterator_create(job_gres_list);
+	while ((gres_state_job = (gres_state_t *) list_next(job_gres_iter))) {
+		if (xstrcasecmp(gres_state_job->gres_name, "gpu") != 0) continue;
+		request_gpu = true;
+		break;
+	}
+	list_iterator_destroy(job_gres_iter);
+	return request_gpu;
+}
+
+/*
+ * _globres_job_hero - check if this job is a hero job or not.
+ * job_ptr		IN - the job data structure
+ * RET true if this job is a hero job and false otherwise
+ */
+bool _globres_job_hero(job_record_t *job_ptr)
+{
+	bool globres_hero_job;
+
+	if (!globres_enabled)
+		return false;
+
+	globres_hero_job = job_ptr->qos_ptr &&
+		(strstr(job_ptr->qos_ptr->name, "globres_hero") != NULL);
+	return globres_hero_job;
+}
