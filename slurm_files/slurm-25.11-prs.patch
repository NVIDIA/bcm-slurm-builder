+	if (curl_global_init(CURL_GLOBAL_ALL) != CURLE_OK) {
+		error("curl_easy_perform() failed: %s",
+			curl_easy_strerror(res));
+		res = SLURM_ERROR;
+	}
+
+	s_p_hashtbl_destroy(globres_hashtbl);
+	xfree(globres_conf);
+
+	return res;
+}
+
+/*
+ * globres_fini - called when the plugin is unloaded. Free all memory.
+ */
+extern int globres_fini(void)
+{
+	xfree(globres_service_addr);
+	xfree(cert_key);
+	xfree(cert_pem);
+	xfree(cacert_pem);
+
+	curl_global_cleanup();
+
+	return SLURM_SUCCESS;
+}
