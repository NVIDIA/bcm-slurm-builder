+/*
+ * globres_is_job_merge_valid - verifies that the two jobs are both
+ *	 hero or both non hero jobs.
+ * from_job_ptr		IN - the first job data structure
+ * from_job_ptr		IN - the second job data structure
+ * RET the returned values from the globres service
+ */
+extern int globres_is_job_merge_valid(job_record_t *from_job_ptr,
+	job_record_t *to_job_ptr)
+{
+	bool from_job_hero_job = _globres_job_hero(from_job_ptr);
+	bool to_job_hero_job = _globres_job_hero(to_job_ptr);
+	if (from_job_hero_job != to_job_hero_job) {
+		error("Attempt to merge hero with non-hero job");
+		return SLURM_ERROR;
+	}
+	return SLURM_SUCCESS;
+}
