+/*
+ * globres_test_hero_job_feasible - sends request to the globres service to
+ *	 verify there is enough of the global resource for this hero job.
+ * job_ptr		IN - the job data structure
+ * RET the returned values from the globres service
+ */
+extern int globres_test_hero_job_feasible(job_record_t *job_ptr)
+{
+	int res = SLURM_SUCCESS;
+	char url[256];
+	response_memory_t response_memory;
+	bool hero_job = _globres_job_hero(job_ptr);
+	bool gpu_job = _globres_job_request_gpu(job_ptr);
+	uint32_t job_num_nodes = job_ptr->details->min_nodes;
+
+	if (!globres_enabled)
+		return SLURM_SUCCESS;
+
+	if (!hero_job)
+		return SLURM_SUCCESS;
+
+	snprintf(url,
+			 sizeof(url),
+			 "%s/test_hero_job_feasible?jobid=%u&num_nodes=%u&is_gpu=%d",
+			 globres_service_addr,
+			 job_ptr->job_id,
+			 job_num_nodes,
+			 gpu_job);
+
+	res = _send_globres_get(url, &response_memory);
+	/*
+	 * Return SLURM_ERROR only if the response is "no".
+	 * In all other cases, such as communication errors, return SLURM_SUCCESS instead.
+	 * This is because returning SLURM_ERROR after SLURM_SUCCESS causes Slurm to mark
+	 * the job with "BadConstraints" and stop retrying.
+	 * Returning SLURM_SUCCESS, however, allows Slurm to keep attempting to schedule the job.
+	 */
+	if (res != SLURM_SUCCESS) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource server unavailable");
+		res = SLURM_SUCCESS;
+	} else if (xstrcmp(response_memory.memory, "{\"message\":\"no\"}") == 0) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource insufficient");
+		res = SLURM_ERROR;
+	}
+	xfree(response_memory.memory);
+	return res;
+}
