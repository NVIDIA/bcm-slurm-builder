+/*
+ * globres_calc_job_num_gpus - determine the requested number of GPUs for this
+ *   job.
+ * job_ptr		IN - the job data structure
+ * RET count of required GPUs for the job
+ */
+extern int globres_calc_job_num_gpus(job_record_t *job_ptr)
+{
+	list_itr_t *job_gres_iter;
+	gres_state_t *gres_state_job;
+	gres_job_state_t *gres_js;
+	uint32_t total_num_gpus = 0;
+	uint32_t sockets_per_node = job_ptr->details->mc_ptr->sockets_per_node;
+	uint32_t ntasks_per_node = MAX(job_ptr->details->ntasks_per_node, 1);
+	uint32_t node_count = job_ptr->details->min_nodes;
+	uint32_t task_count = ntasks_per_node * node_count;
+	list_t *job_gres_list = job_ptr->gres_list_req_accum;
+
+	if (!globres_enabled)
+		return 0;
+
+	if (!job_gres_list || (list_count(job_gres_list) == 0))
+		return 0;
+
+	job_gres_iter = list_iterator_create(job_gres_list);
+	while ((gres_state_job = (gres_state_t *) list_next(job_gres_iter))) {
+		uint32_t num_gpus = 0;
+
+		if (xstrcasecmp(gres_state_job->gres_name, "gpu") != 0) continue;
+
+		gres_js = (gres_job_state_t *) gres_state_job->gres_data;
+		if (gres_js->gres_per_job) {
+			num_gpus = gres_js->gres_per_job;
+		} else if (gres_js->gres_per_node) {
+			num_gpus = gres_js->gres_per_node *
+				node_count;
+		} else if (gres_js->gres_per_socket) {
+			num_gpus = gres_js->gres_per_socket *
+				node_count * sockets_per_node;
+		} else if (gres_js->gres_per_task) {
+			num_gpus = gres_js->gres_per_task * task_count;
+		} else
+			continue;
+		total_num_gpus += num_gpus;
+	}
+	list_iterator_destroy(job_gres_iter);
+	return total_num_gpus;
+}
