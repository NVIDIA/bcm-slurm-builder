+/*
+ * globres_init - initialization of the globres feature.
+ * Returns SLURM_SUCCESS if globres feature is enabled, otherwise SLURM_ERROR.
+ */
+extern int globres_init(void)
+{
+	int res = SLURM_SUCCESS;
+	int fd;
+	s_p_hashtbl_t *globres_hashtbl = NULL;
+	char *globres_conf;
+	static s_p_options_t globres_options[] = {
+		{"GlobresServiceAddr", S_P_STRING},
+		{"CertKey", S_P_STRING},
+		{"CertPem", S_P_STRING},
+		{"CacertPem", S_P_STRING},
+		{NULL}
+	};
+
+	globres_conf = get_extra_conf_path("globres.conf");
+	fd = open(globres_conf, 0);
+	if (fd >= 0) {
+		close(fd);
+	} else {
+		verbose("Unable to find configuration file %s. Globres feature is disabled",
+				globres_conf);
+		return SLURM_ERROR;
+	}
+
+	globres_hashtbl = s_p_hashtbl_create(globres_options);
+	if (s_p_parse_file(globres_hashtbl, NULL, globres_conf, 0, NULL) == SLURM_ERROR) {
+		verbose("Could not parse %s. Globres feature is disabled", globres_conf);
+		s_p_hashtbl_destroy(globres_hashtbl);
+		return SLURM_ERROR;
+	}
+
+	if (s_p_get_string(&globres_service_addr, "GlobresServiceAddr", globres_hashtbl)) {
+		verbose("Globres service address (GlobresServiceAddr): %s",
+			globres_service_addr);
+	} else {
+		verbose("Could not find GlobresServiceAddr in %s. Globres feature is disabled",
+				globres_conf);
+		res = SLURM_ERROR;
+	}
+
+	if (s_p_get_string(&cert_key, "CertKey", globres_hashtbl)) {
+		verbose("Cert key (CertKey): %s", cert_key);
+	} else {
+		verbose("Could not find CertKey in %s. Client verification in mTLS is disabled.",
+				globres_conf);
+	}
+	if (s_p_get_string(&cacert_pem, "CacertPem", globres_hashtbl)) {
