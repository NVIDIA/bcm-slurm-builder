+/*
+ * globres_test_job_global_resource_available - prepare preempted_jobids and ask
+ *   the globres service if there is enough of the resource considering the
+ *   preempted jobs.
+ * job_ptr				IN - the job data stucture
+ * terminated_jobids	IN - list of job ids that the globres service should
+ *   consider as finished when evaluating resource availability for the new job.
+ * node_bitmap			IN - current node allocation for the job
+ */
+extern int globres_test_job_global_resource_available(job_record_t *job_ptr,
+	list_t *terminated_jobids,
+	bitstr_t *node_bitmap)
+{
+	int res = SLURM_SUCCESS;
+	char *url = NULL;
+	char *preempt_jobids_str = NULL, *job_nodes_str = NULL;
+	size_t url_len = 0;
+	char job_id_str[12];
+	response_memory_t response_memory;
+	bool hero_job = _globres_job_hero(job_ptr);
+	bool gpu_job = _globres_job_request_gpu(job_ptr);
+
+	if (!globres_enabled)
+		return SLURM_SUCCESS;
+
+	snprintf(job_id_str, sizeof(job_id_str), "%u", job_ptr->job_id);
+
+	preempt_jobids_str = _jobid_list_to_str(terminated_jobids);
+	if (!preempt_jobids_str) {
+		return SLURM_ERROR;
+	}
+	debug("preempt_jobids_str %s", preempt_jobids_str);
+
+	job_nodes_str = bitmap2node_name(node_bitmap);
+	url_len = strlen(globres_service_addr) +
+			  strlen("/test_job_global_resource_available?jobid=") +
+			  strlen(job_id_str) +
+			  strlen("&job_nodes=") +
+			  strlen(job_nodes_str) +
+			  strlen("&preempted_jobids=") +
+			  strlen(preempt_jobids_str) +
+			  strlen("&is_hero=1") +
+			  strlen("&is_gpu=1") +
+			  1; /* Add 1 for null terminator */
+
+	url = xmalloc(url_len);
+	if (!url) {
+		error("Failed to allocate memory for URL");
+		xfree(preempt_jobids_str);
+		xfree(job_nodes_str);
+		return SLURM_ERROR;
+	}
+
+	snprintf(url,
+			 url_len,
+			 "%s/test_job_global_resource_available?jobid=%s&job_nodes=%s&preempted_jobids=%s&is_hero=%d&is_gpu=%d",
+			 globres_service_addr,
+			 job_id_str,
+			 job_nodes_str,
+			 preempt_jobids_str,
+			 hero_job,
+			 gpu_job);
+	xfree(preempt_jobids_str);
+	xfree(job_nodes_str);
+
+	res = _send_globres_get(url, &response_memory);
+	if (res != SLURM_SUCCESS) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource server unavailable");
+	} else if (xstrcmp(response_memory.memory, "{\"message\":\"yes\"}") != 0) {
+		job_ptr->state_reason = WAIT_RESOURCES;
+		xfree(job_ptr->state_desc);
+		job_ptr->state_desc = xstrdup("Global resource insufficient");
+		res = SLURM_ERROR;
+	}
+	xfree(response_memory.memory);
+	xfree(url);
+	return res;
+}
