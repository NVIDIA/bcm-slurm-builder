+/*
+ * globres_get_jobids - return a list of job ids from a list of job pointers.
+ * jobs		IN - list of job pointers
+ * jobids	IN/OUT - will contain only the job ids of the given jobs
+ */
+extern void globres_get_jobids(list_t *jobs,
+	list_t *jobids)
+{
+	job_record_t *tmp_job_ptr;
+	list_itr_t *job_iterator = NULL;
+
+	if (!globres_enabled)
+		return;
+
+	if (!jobs || (slurm_list_count(jobs) == 0)) {
+		return;
+	}
+
+	job_iterator = list_iterator_create(jobs);
+
+	while ((tmp_job_ptr = list_next(job_iterator))) {
+		list_append(jobids, &tmp_job_ptr->job_id);
+	}
+
+	list_iterator_destroy(job_iterator);
+}
