+ * Unless required by applicable law or agreed to in writing, software
+ * distributed under the License is distributed on an "AS IS" BASIS,
+ * WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+ * See the License for the specific language governing permissions and
+ * limitations under the License.
+\*****************************************************************************/
+
+#include <string.h>
+#include <curl/curl.h>
+#include "select_cons_tres.h"
+#include "globres.h"
+
+/* Read from configuration file */
+char *globres_service_addr = NULL;
+char *cert_key = NULL;
+char *cert_pem = NULL;
+char *cacert_pem = NULL;
+
+typedef struct {
+	char *memory;
+	size_t size;
+} response_memory_t;
+
+/*
+ * _write_callback - callback function for curl requests.
+ */
+size_t _write_callback(char *contents,
+	size_t size,
+	size_t nmemb,
+	void *userdata)
+{
+	size_t real_size = size * nmemb;
+	response_memory_t *mem = (response_memory_t *)userdata;
+
+	char *ptr = xrealloc(mem->memory, mem->size + real_size + 1);
+	if(ptr == NULL) {
+		error("Not enough memory");
+		return 0;
+	}
+
+	mem->memory = ptr;
+	memcpy(&(mem->memory[mem->size]), contents, real_size);
+	mem->size += real_size;
+	mem->memory[mem->size] = 0;
+
+	return real_size;
+}
+
+/*
+ * _jobid_list_to_str - convert a list of job IDs to a comma-separated string.
+ * jobids	IN - list of job ids
+ */
+char* _jobid_list_to_str(list_t *jobids) {
+	size_t total_len = 0;
+	uint32_t *p_job_id;
+	char *result = NULL, *ptr = NULL;
+	list_itr_t *iterator = NULL;
+	int i = 0;
+
+	if (!jobids || slurm_list_count(jobids) == 0) {
+		result = xmalloc(1);
+		*result = '\0';
+		return result;
+	}
+
+	iterator = list_iterator_create(jobids);
+
+	while ((p_job_id = list_next(iterator))) {
+		total_len += snprintf(NULL, 0, "%u", *p_job_id) + 1;  /* +1 for the comma */
+	}
+	total_len++;  /* For the null terminator */
+
+	result = xmalloc(total_len);
+	if (!result) {
+		error("Failed to allocate memory for jobids string");
+		list_iterator_destroy(iterator);
+		return NULL;
+	}
+
+	list_iterator_reset(iterator);
+
+	/* Build the comma-separated string */
+	ptr = result;
+	while ((p_job_id = list_next(iterator))) {
+		if (i > 0) {
+			*ptr++ = ',';  /* Add comma separator */
+		}
+		ptr += sprintf(ptr, "%u", *p_job_id);
+		i++;
+	}
+	*ptr = '\0';  /* Null-terminate the string */
+
+	list_iterator_destroy(iterator);
+	return result;
+}
+
+/*
+ * Callback for libcurl tracing - print out datatype and data
+ */
+static int _libcurl_trace(CURL *handle, curl_infotype type, char *data,
+			  size_t size, void *userp)
+{
+	switch (type) {
+        case CURLINFO_TEXT:
+            log_flag(SELECT_TYPE, "libcurl: %.*s", (int)size, data);
+            break;
+        case CURLINFO_HEADER_IN:
+            log_flag(SELECT_TYPE, "libcurl [HEADER IN]: %.*s", (int)size, data);
+            break;
+        case CURLINFO_HEADER_OUT:
+            log_flag(SELECT_TYPE, "libcurl [HEADER OUT]: %.*s", (int)size, data);
+            break;
+        case CURLINFO_DATA_IN:
+            log_flag(SELECT_TYPE, "libcurl [DATA IN]: Received %zu bytes", size);
+            break;
+        case CURLINFO_DATA_OUT:
+            log_flag(SELECT_TYPE, "libcurl [DATA OUT]: Sent %zu bytes", size);
+            break;
+        default:
+            log_flag(SELECT_TYPE, "libcurl: Other info type %d", type);
+            break;
+	}
+	return 0;
+}
+
+/*
+ * _set_curl_opts - set options to libcurl for the specific query.
+ * url				IN - base url
+ * curl				IN - query data structure
+ * response_memory	IN/OUT - contains the returned body
+ */
+int _set_curl_opts(char* url,
+	CURL *curl,
+	response_memory_t *response_memory)
+{
+	CURLcode res;
+
+	/* Enable verbose output.
+	 * Set DebugFlags=SelectType in slurm.conf to see these logs.
+	 */
+	res = curl_easy_setopt(curl, CURLOPT_DEBUGFUNCTION, _libcurl_trace);
+	if (res != CURLE_OK) {
+		error("Error setting DEBUGFUNCTION: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+	res = curl_easy_setopt(curl, CURLOPT_VERBOSE, 1L);
+	if (res != CURLE_OK) {
+		error("Error setting VERBOSE mode: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+
+	/* Set the CA certificate to verify the server's certificate */
+	if (cacert_pem != NULL) {
+		res = curl_easy_setopt(curl, CURLOPT_CAINFO, cacert_pem);
+		if (res != CURLE_OK) {
+			error("Error setting CAINFO: %s", curl_easy_strerror(res));
+			return SLURM_ERROR;
+		}
+	}
+
+	/* Set the client certificate and private key for client authentication */
+	if ((cert_key != NULL) && (cert_pem != NULL)) {
+		res = curl_easy_setopt(curl, CURLOPT_SSLCERT, cert_pem);
+		if (res != CURLE_OK) {
+			error("Error setting SSLCERT: %s", curl_easy_strerror(res));
+			return SLURM_ERROR;
+		}
+		res = curl_easy_setopt(curl, CURLOPT_SSLKEY, cert_key);
+		if (res != CURLE_OK) {
+			error("Error setting SSLKEY: %s", curl_easy_strerror(res));
+			return SLURM_ERROR;
+		}
+	}
+
+	res = curl_easy_setopt(curl, CURLOPT_URL, url);
+	if (res != CURLE_OK) {
+		error("Error setting URL: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+
+	res = curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, _write_callback);
+	if (res != CURLE_OK) {
+		error("Error setting WRITEFUNCTION: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+	res = curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)response_memory);
+	if (res != CURLE_OK) {
+		error("Error setting WRITEDATA: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+
+	return SLURM_SUCCESS;
+}
+
+/*
+ * _send_globres_get - send the globres service a GET query.
+ * url				IN - base url
+ * response_memory	IN/OUT - contains the returned body. Caller must release
+ *   response_memory->memory
+ */
+int _send_globres_get(char* url,
+	response_memory_t *response_memory)
+{
+	CURLcode res;
+	CURL *curl;
+	int ret = SLURM_SUCCESS;
+
+	response_memory->memory = xmalloc(1);
+	response_memory->size = 0;
+	*response_memory->memory = '\0';
+
+	debug("About to send get query: %s", url);
+
+	curl = curl_easy_init();
+	if(!curl) {
+		error("Failed to initialize CURL session");
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	if (_set_curl_opts(url, curl, response_memory) != SLURM_SUCCESS) {
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	res = curl_easy_perform(curl);
+	if(res != CURLE_OK) {
+		error("curl_easy_perform() failed: %s", curl_easy_strerror(res));
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	debug("Response code: %s, response data (%lu bytes): %s",
+		  curl_easy_strerror(res),
+		  (unsigned long)response_memory->size,
+		  response_memory->memory);
+
+cleanup:
+	curl_easy_cleanup(curl);
+	return ret;
+}
+
+/*
+ * _send_globres_post - send the globres service a POST query.
+ * url				IN - base url
+ * json_body		IN - body of the post request
+ * response_memory	IN/OUT - contains the returned body. Caller must release
+ *   response_memory->memory
+ */
+int _send_globres_post(char* url,
+	char* json_body,
+	response_memory_t *response_memory)
+{
+	CURLcode res;
+	CURL *curl;
+	struct curl_slist *headers = NULL;
+	int ret = SLURM_SUCCESS;
+
+	response_memory->memory = xmalloc(1);
+	response_memory->size = 0;
+	*response_memory->memory = '\0';
+
+	debug("About to send post query: %s", url);
+
+	curl = curl_easy_init();
+	if(!curl) {
+		error("Failed to initialize CURL session");
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	if (_set_curl_opts(url, curl, response_memory) != SLURM_SUCCESS) {
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	headers = curl_slist_append(headers, "Content-Type: application/json");
+	res = curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
+	if (res != CURLE_OK) {
+		error("Error setting HTTPHEADER: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+	res = curl_easy_setopt(curl, CURLOPT_POSTFIELDS, json_body);
+	if (res != CURLE_OK) {
+		error("Error setting POSTFIELDS: %s", curl_easy_strerror(res));
+		return SLURM_ERROR;
+	}
+
+	res = curl_easy_perform(curl);
+	if(res != CURLE_OK) {
+		error("curl_easy_perform() failed: %s", curl_easy_strerror(res));
+		ret = SLURM_ERROR;
+		goto cleanup;
+	}
+
+	debug("Response code: %s, response data (%lu bytes): %s",
+		  curl_easy_strerror(res),
+		  (unsigned long)response_memory->size,
+		  response_memory->memory);
+
+cleanup:
+	curl_easy_cleanup(curl);
+	if (headers != NULL) {
+		curl_slist_free_all(headers);
+	}
+	return ret;
+}
