+				globres_conf);
+	}
+
+	if (s_p_get_string(&cert_pem, "CertPem", globres_hashtbl)) {
+		verbose("Cert pem (CertPem): %s", cert_pem);
+	} else {
+		verbose("Could not find CertPem in %s. TLS is disabled",
+				globres_conf);
