# Description: the script ensures all required for enroot directories are created
#

set -exuo pipefail

command -v enroot >/dev/null || exit 0  # enroot not installed

if [ -z "$SLURM_JOB_UID" ]; then
    echo "ERROR: \$SLURM_JOB_UID is undefined"
    exit 1
fi

if [ -z "$SLURM_JOB_ID" ]; then
    echo "ERROR: \$SLURM_JOB_ID is undefined"
    exit 1
fi

if [ -z "$SLURM_JOB_USER" ]; then
    echo "ERROR: \$SLURM_JOB_USER is undefined"
    exit 1
fi

function create_path() {
    local base_path=$1
    local suffix=$2
    local base_dir=$(sudo -u "$SLURM_JOB_USER" sh -c "echo $base_path")
    local full_path="$base_dir/$suffix"
    local parent_dir=$( dirname "$base_dir" )
    mkdir -p "$full_path"
    chmod 0755 "$base_dir" "$parent_dir"
    chmod 0700 "$full_path"
    chown "$SLURM_JOB_UID:$(id -g "$SLURM_JOB_UID")" "$full_path"
}

{% if ENROOT_RUNTIME_PATH  %}
create_path "{{ ENROOT_RUNTIME_PATH }}" $SLURM_JOB_ID
{% else -%}
# cm-wlm-setup: default enroot runtime directory path is used, thus we don't create a job ID subdirectory
# create_path "/run/enroot/runtime" $SLURM_JOB_ID
{% endif %}

{% if ENROOT_DATA_PATH  %}
create_path "{{ ENROOT_DATA_PATH }}" $SLURM_JOB_UID
{% else -%}
# cm-wlm-setup: default enroot data directory path is used, thus we don't create a UID subdirectory
# create_path "/run/enroot/runtime" $SLURM_JOB_UID
{% endif %}

{% if ENROOT_CACHE_PATH %}

{% if SHARE_CACHE %}
# cm-wlm-setup: cache sharing is enabled, thus we don't create a UID subdirectory
# create_path "{{ ENROOT_CACHE_PATH }}" $SLURM_JOB_UID
{% else -%}
create_path "{{ ENROOT_CACHE_PATH }}" $SLURM_JOB_UID
{% endif %}

{% else -%}
# cm-wlm-setup: default enroot cache directory path is used, thus we don't create a UID subdirectory
# create_path "/run/enroot/cache" $SLURM_JOB_UID
{% endif %}

exit 0
