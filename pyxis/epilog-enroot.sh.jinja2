# Description: the script ensures all unused enroot data is cleaned up
#

set -exuo pipefail

command -v enroot >/dev/null || exit 0  # enroot not installed

if [ -z "$SLURM_JOB_ID" ]; then
    echo "ERROR: \$SLURM_JOB_ID is undefined"
    exit 1
fi

if [ -z "$SLURM_JOB_USER" ]; then
    echo "ERROR: \$SLURM_JOB_USER is undefined"
    exit 1
fi

{% if ENROOT_RUNTIME_PATH -%}
runtime_path=$(sudo -u "$SLURM_JOB_USER" sh -c 'echo "{{ ENROOT_RUNTIME_PATH }}"')
{% else -%}
runtime_base_dir="$(sudo -u "$SLURM_JOB_USER" sh -c 'echo $XDG_RUNTIME_DIR')"
if [ -n "${runtime_base_dir:-}" ]; then
    runtime_path="$runtime_base_dir/enroot"
fi
{% endif -%}

if [ -n "${runtime_path:-}" ]; then
    full_runtime_path="$runtime_path/$SLURM_JOB_ID"
    if [ -d "$full_runtime_path" ]; then
        rm -rf "$full_runtime_path"
    fi
fi

exit 0
